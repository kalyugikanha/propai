# =============================================
# PropAI Backend — Environment Variables
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ----- Google Gemini AI -----
GEMINI_API_KEY=your_gemini_api_key_here

# ----- Google Sheets -----
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here
# Paste the entire service account JSON as a single line (escape newlines in private_key)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\\n...\\n-----END RSA PRIVATE KEY-----\\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Alternatively, point to the JSON key file path (use one or the other, JSON string takes priority)
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./credentials/service-account.json

# ----- Server -----
PORT=3000
NODE_ENV=development

# ----- CORS (comma-separated origins, or * for all) -----
# In production, set this to your WordPress site domain
CORS_ORIGIN=*

# ----- Session -----
SESSION_TTL_HOURS=2

# ----- Property Search -----
TOP_PROPERTIES_LIMIT=5

# ----- Rate Limiting -----
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=900000

# ----- Logging -----
LOG_LEVEL=info

# ----- Agency Branding -----
AGENCY_NAME=PropAI Jaipur
AGENT_NAME=Priya
